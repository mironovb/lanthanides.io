// lanthanides.io - Prisma schema (dynamic, user-generated side).
//
// Only genuinely dynamic, user-generated data lives here. The reference /
// provenance dataset stays in versioned files under _data/ and is read by the
// typed data layer in lib/data/. It is NEVER mirrored into the database, and a
// row here is NEVER auto-published back into the open dataset (that stays the
// reviewed git-PR flow). See docs/ARCHITECTURE.md §4.
//
// Postgres everywhere: local dev AND production (the migration's original
// "SQLite for dev" stance was superseded at deploy; see docs/DEPLOYMENT.md).
// `DATABASE_URL` is the connection used at runtime (point it at a POOLED endpoint
// on serverless hosts); `DIRECT_URL` is the direct connection Prisma Migrate uses
// (set both to the same direct URL for a local/Docker Postgres). The schema still
// avoids engine-specific constructs: no native `enum` (status/channel/origin are
// "enum-like" Strings) and no scalar lists (`topics` is a CSV String, not
// String[]), so it stays simple and easy to reason about.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Seller submissions captured at /sell (write path: POST /api/listings, P8).
/// Storage-only here: moderation/approval, contact reveal, payments, and public
/// display are later prompts. A Listing is NEVER auto-published into the open
/// dataset in _data/ (docs/ARCHITECTURE.md §4.2).
model Listing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // What is being offered. `elementSymbol` is the case-sensitive catalog symbol
  // (e.g. 'Dy'); the catalog lives in _data/ files, so this is a logical FK only
  // (not DB-enforced). `form`/`purity` mirror the _data/ vocabularies.
  elementSymbol    String
  form             String
  purity           String
  quantityKg       Float
  askingPricePerKg Float
  currency         String @default("USD")

  // Seller identity. `sellerContact` is private and OPTIONAL, never published.
  sellerName    String
  sellerContact String?
  notes         String?

  // Workflow state: enum-like String:
  // 'pending' (captured) | 'reviewed' | 'published'. Portable to Postgres as-is.
  status String @default("pending")

  // Price-gauge snapshot at submission time (lib/price-gauge.ts over the price
  // dataset), frozen so the listing records where the asking price sat vs the
  // retail/bulk references the day it was created. All nullable: the gauge may
  // resolve no reference for a thinly-covered element (surface the gap, never
  // fabricate. See hard rule #1.
  gaugeLow        Float?
  gaugeMid        Float?
  gaugeHigh       Float?
  gaugeConfidence String? // 'low' | 'medium' | 'high'

  @@index([elementSymbol])
  @@index([status])
  @@map("listings")
}

/// Notification signups captured at /alerts (write path: POST /api/subscribe, P8).
/// Minimal and privacy-respecting: store only what a channel needs to deliver.
/// Telegram exists end-to-end today (scripts/notify/telegram.py); email delivery,
/// double-opt-in, and per-topic routing are later prompts (storage-only here).
/// docs/ARCHITECTURE.md §4.3.
model Subscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Delivery channel: enum-like String: 'telegram' | 'email'.
  channel String

  // Destination. OPTIONAL because a Telegram signup may carry no email (chat-id
  // wiring is a later prompt); never store more than the channel needs.
  email String?

  // Topics of interest: CSV of 'regulatory' | 'price-movements'.
  // Empty string ⇒ all topics.
  topics String @default("")

  // Lifecycle: enum-like String: 'waitlist' (captured, not yet delivering) |
  // 'active'. `confirmedAt` is set when a double-opt-in completes (later prompt).
  status      String    @default("waitlist")
  confirmedAt DateTime?

  @@index([channel])
  @@map("subscriptions")
}

/// Backing table for the screened-offer feed at /offers (ISR, P8).
/// SEEDED tonight from the public price dataset (prisma/seed.ts, origin='seed')
/// so the demand-side feed has real content. The live screening/ingestion
/// pipeline (parsing, scoring, dedup of real buy/sell offers) is a later prompt;
/// rows it adds carry origin='screened'. docs/ARCHITECTURE.md §4.1.
model ScreenedOffer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  elementSymbol String // case-sensitive catalog symbol, e.g. 'Dy'
  form          String // mirrors _data/ forms ('oxide' | 'metal' | ...)
  purity        String? // nullable: a few source records omit purity
  quantityKg    Float? // nullable: not every source record quotes a quantity
  pricePerKg    Float // normalized USD/kg copied from the source price record
  currency      String  @default("USD")

  // Seller provenance carried over from the source record.
  sellerName    String
  sellerCountry String? // ISO-2; nullable (some source rows omit it)
  sourceType    String // source record's source_type, e.g. 'distributor_offer'
  sourceUrl     String? // optional; absent on every current dataset record
  observedDate  String // source record's quote_date, ISO 'YYYY-MM-DD' (date-only, stored verbatim)

  // Ranking inputs. `confidence` is the source record's numeric confidence_score
  // (0..1). `valueScore` is the computed rank input documented in prisma/seed.ts:
  // how far below the element's same-form median the offer sits, scaled by
  // confidence (higher = better value). Indexed for feed ordering.
  confidence Float
  valueScore Float

  // Provenance of the row itself: enum-like String: 'seed' (public dataset,
  // this prompt) | 'screened' (live pipeline, later prompt).
  origin String @default("screened")

  @@index([elementSymbol])
  @@index([origin])
  @@index([valueScore])
  @@map("screened_offers")
}

/// Discussion threads captured at /discussion (write path:
/// POST /api/discussion/threads). This is dynamic, user-generated coordination
/// content: market notes, source tips, regulatory questions, and site/meta
/// discussion. It is NEVER written into the open reference dataset in _data/.
model DiscussionThread {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title        String
  category     String // 'source-tip' | 'price-question' | 'regulatory-question' | 'data-correction' | 'market-note' | 'site-meta'
  authorName   String
  organization String?
  body         String

  // Structured "source tip" lead fields — ALL optional and public-safe, set only
  // on category='source-tip' threads (see components/discussion/discussion.ts).
  // They turn a free-text tip into a triagable lead for the human review pipeline
  // (CONTRIBUTING.md: a source must be Identifiable, Dated, Specific, Verifiable),
  // but a thread is STILL never auto-published into the open dataset in _data/ —
  // that stays the reviewed git-PR flow. No private contact field is ever added.
  sourceUrl     String? // a public link a reviewer can open (http/https only)
  sourceDate    String? // observed/published date, ISO 'YYYY-MM-DD' (date-only, stored verbatim, mirrors ScreenedOffer.observedDate)
  elementSymbol String? // case-sensitive catalog symbol (e.g. 'Dy'); logical FK to _data/, not DB-enforced

  // Moderation state: enum-like String:
  // 'pending' (held for maintainer review; NOT public) | 'open' | 'answered' |
  // 'locked' (read-only) | 'hidden' (removed; NOT public). New threads default to
  // 'open' (immediate publish); set DISCUSSION_REQUIRE_APPROVAL to create them
  // 'pending' instead. Public reads only ever surface open/answered/locked. The
  // column is a free-form String, so this vocabulary needs no migration to grow.
  // Full model + transitions in docs/DISCUSSION-MODERATION.md.
  status String @default("open")

  replies DiscussionReply[]

  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([elementSymbol])
  @@map("discussion_threads")
}

/// Replies on discussion threads (write path:
/// POST /api/discussion/threads/[id]/replies). Replies carry no private contact
/// field and are stored separately from reference/provenance data.
model DiscussionReply {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  threadId String
  thread   DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  authorName String
  body       String

  // Moderation state: enum-like String: 'pending' (held for review; NOT public) |
  // 'visible' | 'hidden'. Defaults to 'visible' (immediate publish);
  // pre-moderation (DISCUSSION_REQUIRE_APPROVAL) creates 'pending' instead. Only
  // 'visible' replies are ever shown publicly.
  status String @default("visible")

  @@index([threadId])
  @@index([status])
  @@index([createdAt])
  @@map("discussion_replies")
}
