---
layout: null
---
[
{% for elem in site.elements %}
  {% assign cat_info = nil %}
  {% for c in site.data.element_catalog %}
    {% if c.symbol == elem.symbol %}
      {% assign cat_info = c %}
      {% break %}
    {% endif %}
  {% endfor %}
  {
    "symbol": {{ elem.symbol | jsonify }},
    "name": {{ elem.name | jsonify }},
    "atomic_number": {{ cat_info.atomic_number | jsonify }},
    "category": {{ cat_info.category | jsonify }},
    "export_control": {{ cat_info.export_control_status | jsonify }},
    "family": {{ cat_info.family | jsonify }},
    "url": {{ elem.url | relative_url | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
