---
layout: null
permalink: /movements.xml
sitemap: false
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title>{{ site.title | xml_escape }} — Market Movements</title>
  <subtitle>Auto-generated price-movement and regulatory-change alerts for rare earth and strategic metals.</subtitle>
  <link href="{{ '/movements.xml' | absolute_url }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/movements/' | absolute_url }}" rel="alternate" type="text/html"/>
  <id>{{ '/movements.xml' | absolute_url }}</id>
  {% assign mv_doc = site.data.movements %}
  {% assign mv_events = mv_doc.events %}
  {% if mv_events == nil %}{% assign mv_events = "" | split: "" %}{% endif %}
  {% if mv_doc.state.last_run %}<updated>{{ mv_doc.state.last_run }}</updated>{% else %}<updated>{{ site.time | date_to_xmlschema }}</updated>{% endif %}
  <generator uri="https://github.com/mironovb/lanthanides.io" version="1.0">scripts/detect_movements.py</generator>
  <author>
    <name>{{ site.author | default: "lanthanides.io" | xml_escape }}</name>
    <uri>{{ '/' | absolute_url }}</uri>
  </author>
  <rights>CC BY 4.0 — https://creativecommons.org/licenses/by/4.0/</rights>
  {% for event in mv_events limit:50 %}
    {% capture event_anchor %}/movements/#mv-{{ event.id }}{% endcapture %}
    {% assign event_url = event_anchor | absolute_url %}
    {% capture element_url %}{{ event.element_url | absolute_url }}{% endcapture %}
    {% case event.type %}
      {% when 'price_spike' %}{% assign event_kind = 'Price spike' %}
      {% when 'price_drop' %}{% assign event_kind = 'Price drop' %}
      {% when 'regulatory_change' %}{% assign event_kind = 'Regulatory change' %}
      {% when 'new_data' %}{% assign event_kind = 'New data' %}
      {% else %}{% assign event_kind = 'Movement' %}
    {% endcase %}
    {% capture event_title %}{{ event_kind }} · {{ event.element_name | xml_escape }} ({{ event.element }}){% if event.tier_label %} — {{ event.tier_label }}{% endif %}{% if event.abs_magnitude_pct %} {% if event.direction == 'up' %}+{% elsif event.direction == 'down' %}−{% endif %}{{ event.abs_magnitude_pct }}%{% endif %}{% endcapture %}
  <entry>
    <title>{{ event_title | xml_escape }}</title>
    <link href="{{ event_url }}" rel="alternate" type="text/html"/>
    <id>tag:{{ site.url | replace: 'https://', '' | replace: 'http://', '' | replace: '/', '' }},{{ event.date }}:movement/{{ event.id }}</id>
    <published>{{ event.date }}T00:00:00Z</published>
    <updated>{{ event.date }}T00:00:00Z</updated>
    <category term="{{ event.type }}"/>
    {% if event.tier %}<category term="tier-{{ event.tier }}"/>{% endif %}
    {% if event.element %}<category term="element-{{ event.element }}"/>{% endif %}
    <summary type="text">{{ event.description | xml_escape }}</summary>
    <content type="html">
      &lt;p&gt;{{ event.description | xml_escape }}&lt;/p&gt;
      {% if event.start_price_per_kg and event.end_price_per_kg %}
      &lt;p&gt;&lt;strong&gt;Window:&lt;/strong&gt; {{ event.start_date }} → {{ event.end_date }} ({{ event.actual_span_days }} days)&lt;br/&gt;
      &lt;strong&gt;Price:&lt;/strong&gt; ${{ event.start_price_per_kg }}/kg → ${{ event.end_price_per_kg }}/kg ({% if event.direction == 'up' %}+{% elsif event.direction == 'down' %}−{% endif %}{{ event.abs_magnitude_pct }}%)&lt;br/&gt;
      &lt;strong&gt;Observations:&lt;/strong&gt; {{ event.observation_count }} across {{ event.distinct_days }} day(s) · confidence: {{ event.confidence }}&lt;/p&gt;
      {% endif %}
      &lt;p&gt;See &lt;a href="{{ element_url }}"&gt;{{ event.element_name | xml_escape }} on lanthanides.io&lt;/a&gt;.&lt;/p&gt;
    </content>
  </entry>
  {% endfor %}
</feed>
