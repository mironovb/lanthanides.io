source "https://rubygems.org"

# Use github-pages gem when deploying to GitHub Pages.
# For local development, use jekyll directly.
# Uncomment the github-pages line and comment out jekyll for GH Pages deployment:
# gem "github-pages", group: :jekyll_plugins

gem "jekyll", "~> 4.4"
gem "webrick" # required for Jekyll 4+ local server

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end
