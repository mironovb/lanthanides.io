# ── lanthanides.io — example environment ─────────────────────────────────────
# Copy to `.env` for local development. `.env` is gitignored — never commit it,
# and never put real credentials or paid-service keys here (CLAUDE.md hard rule).
#
# Database: Postgres everywhere (local dev AND production). See docs/DEPLOYMENT.md.
#   • DATABASE_URL — connection used at runtime. On a serverless host (e.g. Vercel)
#     point this at a POOLED endpoint (Neon `-pooler`, Supabase port 6543, PgBouncer).
#   • DIRECT_URL  — direct (non-pooled) connection used by `prisma migrate`.
#     For a local/Docker Postgres, set both to the same direct URL.
#
# Spin up a throwaway local Postgres in one line (Docker):
#   docker run --name lanth-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
# then:  npx prisma migrate deploy  &&  npx prisma db seed
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lanthanides?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/lanthanides?schema=public"

# Public Telegram handle for the MOFCOM export-control alert bot. NEXT_PUBLIC_ →
# inlined into the client bundle at build, so it must be PUBLIC-safe (a bot/channel
# URL, never a token). The regulatory monitor already fires Telegram alerts on
# critical announcements; set this to the public bot link and the "Get alerts" CTAs
# link straight to it. Left as the placeholder (or unset), the UI routes to /alerts/
# instead of shipping a guessed/dead link (CLAUDE.md hard rule #1).
# TODO(owner): replace the placeholder with the real https://t.me/<handle>.
NEXT_PUBLIC_TELEGRAM_BOT_URL="https://t.me/your_bot_handle"

# Optional: status flag for the /offers screening banner (the live screening
# backend is stubbed). Leave unset for the honest "screening in development" state.
# SCREENING_BACKEND=

# ── Discussion moderation (both OPTIONAL; the board works fully without them) ──
# Full model: docs/DISCUSSION-MODERATION.md.
#
# Pre-moderation. When truthy (1/true/yes/on), new discussion threads and replies
# are held as `pending` (not public) until a maintainer approves them. Unset /
# false (default) = post-moderation: posts publish immediately and a maintainer
# may hide or lock them afterward. Only enable this if you are actively reviewing
# the queue, or the board will look empty to contributors.
# DISCUSSION_REQUIRE_APPROVAL=
#
# Maintainer moderation API secret. SERVER-ONLY — never prefix with NEXT_PUBLIC_
# (that would inline it into the client bundle). Unset (default) => the endpoint
# at /api/discussion/moderation is DISABLED (returns 404) and nothing can hide /
# lock / approve over HTTP. Set it to a long random string (>=16 chars; shorter
# values are ignored) to enable the secret-gated endpoint, then send it as
# `Authorization: Bearer <secret>`. This is a single shared secret for a solo
# maintainer, not multi-user auth. Never commit a real value.
# DISCUSSION_MODERATION_SECRET=
