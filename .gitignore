# Redesign tooling — do not push. Anchored to repo root so these don't also
# match nested dirs like scripts/analyzer/prompts/ (which IS version-controlled).
/prompts/
/logs/
/run-all.sh

# Outreach — never commit real supplier contacts, local scratch files, or drafts
outreach/suppliers.yml
outreach/*.local.*
outreach/drafts/

# Regulatory monitor — commit the dedup DB (seen.sqlite) and run_state.json so
# cloud runs start warm, but never the scraped article bodies or run logs
# (transient; rebuilt each run, and third-party content doesn't belong here).
scripts/scraper/data/articles/
scripts/scraper/scraper.log
