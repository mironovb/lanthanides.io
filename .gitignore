_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
vendor/
.bundle/
*.gem
*.swp
*.swo
*~
.DS_Store
Thumbs.db
__pycache__/
*.pyc
.env
invoices/*.pdf
invoices/*.xlsx
invoices/*.csv
!invoices/.gitkeep

# Redesign tooling — do not push. Anchored to repo root so these only ignore
# top-level tooling dirs, not similarly-named nested dirs elsewhere.
/prompts/
/logs/
/run-all.sh

# Outreach — never commit real supplier contacts, local scratch files, or drafts
outreach/suppliers.yml
outreach/*.local.*
outreach/drafts/

# Regulatory monitor — commit the dedup DB (seen.sqlite) and run_state.json so
# cloud runs start warm, but never the scraped article bodies or run logs
# (transient; rebuilt each run, and third-party content doesn't belong here).
scripts/scraper/data/articles/
scripts/scraper/scraper.log

# ── Next.js / Node (Prompt 3: dynamic app shell) ─────────────────────────────
node_modules/
.next/
/out/
/build/
*.tsbuildinfo
next-env.d.ts
.vercel
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env*.local

# ── Prisma / SQLite (local dev DB — never commit) ────────────────────────────
# NB: the regulatory monitor's dedup DB is `seen.sqlite` (kept above), so only
# the Prisma `*.db` files are ignored here.
*.db
*.db-journal
dev.db
prisma/dev.db

# ── Local agent tooling & scratch (never commit; see CLAUDE.md hard rule #3) ──
# `.arun/` holds local session state including credentials; `combined*.txt` and
# `chat.md` are scratch dumps. Ignoring these stops `git add -A` from sweeping
# secrets into history.
.arun/
/combined*.txt
/chat.md
